{
  "manifest_version": 3,
  "name": "Flow Breaker Shield",
  "description": "Emergency porn blocking and 21-day website locks for Flow Breaker.",
  "version": "1.0.0",
  "action": {
    "default_title": "Flow Breaker Shield",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-detector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.css",
        "blocked.js",
        "icon.svg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
